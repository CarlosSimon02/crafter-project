<?xml version="1.0" encoding="UTF-8"?>
<form>
  <title>Component - Hero</title>
  <description>Full-width hero banner with cyan background, hero image, centered headline and subtitle</description>
  <objectType>component</objectType>
  <content-type>/component/component-hero</content-type>
  <imageThumbnail></imageThumbnail>
  <quickCreate>false</quickCreate>
  <quickCreatePath></quickCreatePath>
  <properties>
    <property>
      <name>display-template</name>
      <label>Display Template</label>
      <value>/templates/web/components/hero.ftl</value>
      <type>template</type>
    </property>
    <property>
      <name>no-template-required</name>
      <label>No Template Required</label>
      <value></value>
      <type>boolean</type>
    </property>
    <property>
      <name>merge-strategy</name>
      <label>Merge Strategy</label>
      <value>inherit-levels</value>
      <type>string</type>
    </property>
  </properties>
  <sections>
    <section>
      <title>Hero Content</title>
      <description></description>
      <defaultOpen>true</defaultOpen>
      <fields>
        <field>
          <type>input</type>
          <id>internal-name</id>
          <iceId></iceId>
          <title>Internal Name</title>
          <description></description>
          <defaultValue>Hero</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>50</value><type>int</type></property>
            <property><name>maxlength</name><value>50</value><type>int</type></property>
          </properties>
          <constraints>
            <constraint><name>required</name><value><![CDATA[true]]></value><type>boolean</type></constraint>
          </constraints>
        </field>
        <field>
          <type>input</type>
          <id>headline_s</id>
          <iceId></iceId>
          <title>Headline (desktop)</title>
          <description>Single-line headline shown on tablet/desktop (≥ 480px)</description>
          <defaultValue>Small growth for small businesses.</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>100</value><type>int</type></property>
            <property><name>maxlength</name><value>200</value><type>int</type></property>
          </properties>
          <constraints>
            <constraint><name>required</name><value><![CDATA[true]]></value><type>boolean</type></constraint>
          </constraints>
        </field>
        <field>
          <type>input</type>
          <id>headlineMobileLine1_s</id>
          <iceId></iceId>
          <title>Headline mobile — line 1</title>
          <description>First line of the headline on small mobile (&lt; 480px)</description>
          <defaultValue>Small growth for</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>50</value><type>int</type></property>
            <property><name>maxlength</name><value>100</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
        <field>
          <type>input</type>
          <id>headlineMobileLine2_s</id>
          <iceId></iceId>
          <title>Headline mobile — line 2</title>
          <description>Second line of the headline on small mobile (&lt; 480px)</description>
          <defaultValue>small businesses</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>50</value><type>int</type></property>
            <property><name>maxlength</name><value>100</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
        <field>
          <type>textarea</type>
          <id>subtitle1_s</id>
          <iceId></iceId>
          <title>Subtitle (line 1)</title>
          <description>First line of the subtitle below the headline.</description>
          <defaultValue>GoTyme Merchant Cash Advance Asia is a regional provider of fast, flexible financing built for SMEs.</defaultValue>
          <help></help>
          <properties>
            <property><name>cols</name><value>60</value><type>int</type></property>
            <property><name>rows</name><value>3</value><type>int</type></property>
            <property><name>maxlength</name><value>300</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
        <field>
          <type>textarea</type>
          <id>subtitle2_s</id>
          <iceId></iceId>
          <title>Subtitle (line 2)</title>
          <description>Optional second line. Leave empty if not needed.</description>
          <defaultValue></defaultValue>
          <help></help>
          <properties>
            <property><name>cols</name><value>60</value><type>int</type></property>
            <property><name>rows</name><value>3</value><type>int</type></property>
            <property><name>maxlength</name><value>300</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
      </fields>
    </section>
    <section>
      <title>Background Images</title>
      <description>Hero banner background imagery — supports separate sources for desktop / tablet / mobile.</description>
      <defaultOpen>false</defaultOpen>
      <fields>
        <field>
          <type>input</type>
          <id>backgroundImageDesktop_s</id>
          <iceId></iceId>
          <title>Background Image — Desktop (≥ 1024px)</title>
          <description>Path in static-assets. ~1216×653 recommended.</description>
          <defaultValue>/static-assets/images/hero-background.webp</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>100</value><type>int</type></property>
            <property><name>maxlength</name><value>255</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
        <field>
          <type>input</type>
          <id>backgroundImageTablet_s</id>
          <iceId></iceId>
          <title>Background Image — Tablet/Mobile (≤ 1023px)</title>
          <description>Smaller version for narrower viewports.</description>
          <defaultValue>/static-assets/images/hero-background-1x.webp</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>100</value><type>int</type></property>
            <property><name>maxlength</name><value>255</value><type>int</type></property>
          </properties>
          <constraints></constraints>
        </field>
      </fields>
    </section>
  </sections>
  <datasources></datasources>
</form>
