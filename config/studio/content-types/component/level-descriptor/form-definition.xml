<form>
	<title>Section Defaults</title>
	<description>Section Defaults provides inherited values to all children and sibling content items. To learn more about content inheritance see craftercms.com/docs topic &quot;Content Inheritance&quot;</description>
	<objectType>component</objectType>
	<content-type>/component/level-descriptor</content-type>
	<imageThumbnail>undefined</imageThumbnail>
    <quickCreate>false</quickCreate>
    <quickCreatePath></quickCreatePath>
	<properties>		<property>
			<name>display-template</name>
			<label>Display Template</label>
			<value></value>
			<type>template</type>
		</property>
		<property>
			<name>no-template-required</name>
			<label>No Template Required</label>
			<value></value>
			<type>boolean</type>
		</property>
		<property>
			<name>merge-strategy</name>
			<label>Merge Strategy</label>
			<value>inherit-levels</value>
			<type>string</type>
		</property>
	</properties>
	<sections>		<section>
			<title>Section Defaults Properties</title>
			<description></description>
			<defaultOpen>true</defaultOpen>
			<fields>
				<field>
					<type>file-name</type>
					<id>file-name</id>
					<iceId></iceId>
					<title>File Name</title>
					<description></description>
					<defaultValue>crafter-level-descriptor.level</defaultValue>
					<help></help>
					<properties>
						<property>
							<name>size</name>
							<value>100</value>
							<type>int</type>
						</property>
						<property>
							<name>maxlength</name>
							<value>50</value>
							<type>int</type>
						</property>
						<property>
							<name>readonly</name>
							<value>true</value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints>
					</constraints>
				</field>
				<field>
					<type>node-selector</type>
					<id>header_o</id>
					<iceId></iceId>
					<title>Header</title>
					<description>Shared header component inherited by all pages in this folder</description>
					<defaultValue></defaultValue>
					<help></help>
					<properties>
						<property>
							<name>minSize</name>
							<value>0</value>
							<type>int</type>
						</property>
						<property>
							<name>maxSize</name>
							<value>1</value>
							<type>int</type>
						</property>
						<property>
							<name>itemManager</name>
							<value>headerSource</value>
							<type>datasource:item</type>
						</property>
						<property>
							<name>readonly</name>
							<value></value>
							<type>boolean</type>
						</property>
						<property>
							<name>disableFlattening</name>
							<value>false</value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints></constraints>
				</field>
				<field>
					<type>node-selector</type>
					<id>footer_o</id>
					<iceId></iceId>
					<title>Footer</title>
					<description>Shared footer component inherited by all pages in this folder</description>
					<defaultValue></defaultValue>
					<help></help>
					<properties>
						<property>
							<name>minSize</name>
							<value>0</value>
							<type>int</type>
						</property>
						<property>
							<name>maxSize</name>
							<value>1</value>
							<type>int</type>
						</property>
						<property>
							<name>itemManager</name>
							<value>footerSource</value>
							<type>datasource:item</type>
						</property>
						<property>
							<name>readonly</name>
							<value></value>
							<type>boolean</type>
						</property>
						<property>
							<name>disableFlattening</name>
							<value>false</value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints></constraints>
				</field>
			</fields>
		</section>
	</sections>
