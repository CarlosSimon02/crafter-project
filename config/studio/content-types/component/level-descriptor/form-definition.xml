					<type>boolean</type>
				</property>
				<property>
					<name>baseRepoPath</name>
					<value>/site/components/headers</value>
					<type>string</type>
				</property>
				<property>
					<name>baseBrowsePath</name>
					<value>/site/components/headers</value>
					<type>string</type>
				</property>
				<property>
					<name>contentTypes</name>
					<value></value>
					<type>contentTypes</type>
				</property>
				<property>
					<name>tags</name>
					<value></value>
					<type>string</type>
				</property>
			</properties>
		</datasource>
		<datasource>
			<type>components</type>
			<id>footerSource</id>
			<title>Footer Source</title>
			<interface>item</interface>
			<properties>
				<property>
					<name>allowShared</name>
					<value>true</value>
					<type>boolean</type>
				</property>
				<property>
					<name>allowEmbedded</name>
					<value>false</value>
					<type>boolean</type>
				</property>
				<property>
					<name>enableBrowse</name>
					<value>true</value>
					<type>boolean</type>
				</property>
				<property>
					<name>enableSearch</name>
					<value>false</value>
					<type>boolean</type>
				</property>
				<property>
					<name>baseRepoPath</name>
					<value>/site/components/footers</value>
					<type>string</type>
				</property>
				<property>
					<name>baseBrowsePath</name>
					<value>/site/components/footers</value>
					<type>string</type>
				</property>
				<property>
					<name>contentTypes</name>
					<value></value>
					<type>contentTypes</type>
				</property>
				<property>
					<name>tags</name>
					<value></value>
					<type>string</type>
				</property>
			</properties>
		</datasource>
	</datasources>
</form>
