<?xml version="1.0" encoding="UTF-8"?>
<form>
  <title>Locale Redirect</title>
  <description>Redirects the bare site root to the chosen default locale (e.g. / -&gt; /en/)</description>
  <objectType>page</objectType>
  <content-type>/page/page-locale-redirect</content-type>
  <imageThumbnail></imageThumbnail>
  <quickCreate>false</quickCreate>
  <quickCreatePath></quickCreatePath>
  <properties>
    <property>
      <name>display-template</name>
      <label>Display Template</label>
      <value>/templates/web/redirect.ftl</value>
      <type>template</type>
    </property>
    <property>
      <name>no-template-required</name>
      <label>No Template Required</label>
      <value></value>
      <type>boolean</type>
    </property>
    <property>
      <name>merge-strategy</name>
      <label>Merge Strategy</label>
      <value>inherit-levels</value>
      <type>string</type>
    </property>
  </properties>
  <sections>
    <section>
      <title>Redirect Settings</title>
      <description></description>
      <defaultOpen>true</defaultOpen>
      <fields>
        <field>
          <type>input</type>
          <id>internal-name</id>
          <iceId></iceId>
          <title>Internal Name</title>
          <description></description>
          <defaultValue>Locale Redirect</defaultValue>
          <help></help>
          <properties>
            <property><name>size</name><value>50</value><type>int</type></property>
            <property><name>maxlength</name><value>50</value><type>int</type></property>
          </properties>
          <constraints>
            <constraint><name>required</name><value><![CDATA[true]]></value><type>boolean</type></constraint>
          </constraints>
        </field>
        <field>
          <type>dropdown</type>
          <id>defaultLocale_s</id>
          <iceId></iceId>
          <title>Default Locale</title>
          <description>Visitors landing on / will be redirected to this locale's home page.</description>
          <defaultValue>en</defaultValue>
          <help>Add new locales here AND in config/engine/site-config.xml &lt;availableTargetIds&gt;.</help>
          <properties>
            <property>
              <name>datasource</name>
              <value>localesDS</value>
              <type>datasource:value</type>
            </property>
            <property>
              <name>readonly</name>
              <value></value>
              <type>boolean</type>
            </property>
          </properties>
          <constraints>
            <constraint><name>required</name><value><![CDATA[true]]></value><type>boolean</type></constraint>
          </constraints>
        </field>
      </fields>
    </section>
  </sections>
  <datasources>
    <datasource>
      <id>localesDS</id>
      <name>localesDS</name>
      <title>Available Locales</title>
      <type>configured-list-of-pairs</type>
      <interface>value</interface>
      <properties>
        <property>
          <name>dataType</name>
          <value>string</value>
          <type>string</type>
        </property>
        <property>
          <name>options</name>
          <value>[{"value":"en","label":"English (en)"},{"value":"zh","label":"中文 (zh)"}]</value>
          <type>json</type>
        </property>
      </properties>
    </datasource>
  </datasources>
</form>
